{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.design/schemas/entity-relationship.schema.json",
  "title": "Entity Relationship Diagram",
  "description": "Data contract for the entity-relationship format: a data-model diagram for repositories, services, or databases. Entity cards list attributes, keys, indexes, and relationships with cardinality. Unlike data-register, the primary reading task is schema shape and relationship tracing.",
  "type": "object",
  "required": ["meta", "entities", "relationships"],
  "additionalProperties": false,
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "entities": {
      "type": "array",
      "description": "Entity/table/model cards positioned on the canvas.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "x", "y", "attributes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "area": { "type": "string", "description": "Domain/module label shown as a chip." },
          "x": { "type": "number", "description": "Horizontal position on the canvas, 0..100." },
          "y": { "type": "number", "description": "Vertical position on the canvas, 0..100." },
          "status": { "type": "string", "enum": ["ok", "hold", "risk", "neutral"], "default": "neutral" },
          "attributes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "key": { "type": "string", "enum": ["pk", "fk", "unique", "index", "none"], "default": "none" },
                "nullable": { "type": "boolean", "default": false },
                "ref": { "type": "string", "description": "Optional referenced entity.attribute." },
                "note": { "type": "string" }
              }
            }
          },
          "indexes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Cardinality relationships between entities.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "fromCardinality", "toCardinality"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "label": { "type": "string" },
          "fromCardinality": { "type": "string", "enum": ["one", "zero-one", "many", "zero-many", "one-many"] },
          "toCardinality": { "type": "string", "enum": ["one", "zero-one", "many", "zero-many", "one-many"] },
          "fromAttribute": { "type": "string" },
          "toAttribute": { "type": "string" },
          "identifying": { "type": "boolean", "default": false },
          "status": { "type": "string", "enum": ["ok", "hold", "risk", "neutral"], "default": "neutral" }
        }
      }
    },
    "domains": {
      "type": "array",
      "description": "Optional domain legend entries.",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["org", "project", "reportType", "title", "date", "theme"],
      "additionalProperties": false,
      "properties": {
        "org": { "type": "string", "default": "{{ORG}}" },
        "project": { "type": "string", "default": "{{PROJECT}}" },
        "reportType": { "type": "string", "examples": ["Entity Relationship Diagram"] },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string", "default": "{{AUTHOR}}" },
        "theme": { "type": "string", "enum": ["blue", "purple", "indigo", "teal", "cyan", "green", "plum", "slate", "black"], "default": "black" }
      }
    }
  }
}
